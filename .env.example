# Environment variables for Shree Finance AI v3.3
# Copy this file to .env and fill in your real values

# ── Twilio (WhatsApp) ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Groq AI (NLP + Vision) ──
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets (CRM) ──
# Option 1: Local file — place credentials.json in same folder
# Option 2: Render/cloud — paste entire JSON as one line below
GOOGLE_CREDENTIALS=

# ── Flask ──
PORT=5000
